{
  "compilerOptions": {
    "noImplicitAny": true,
    "removeComments": true,
    "preserveConstEnums": true,
    "sourceMap": true,
    "lib": ["ES2021", "DOM"],
      "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "allowImportingTsExtensions": true,
    "noEmit": true

  },
  "include": ["src/**/*"],
  "exclude": ["**/*.spec.ts"]
}